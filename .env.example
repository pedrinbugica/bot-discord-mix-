# OpenAI (obrigatório para o comando /pergunta)
OPENAI_API_KEY=

# Discord (obrigatório)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Mix: staff — quem pode usar /mix reset sem ser admin (ID do cargo). Opcional.
MIX_ADMIN_ROLE_ID=

# Visual do painel (opcional)
# Cor do embed: hex sem # (ex. 5865f2) ou com #
MIX_EMBED_COLOR=5865f2
# Thumbnail do embed (canto): link **direto** ao .png/.jpg (https). Página do Steam/Google não funciona.
# Vazio = logo CS2 por defeito no código. Para desativar: none
# Exemplo: https://upload.wikimedia.org/wikipedia/commons/9/9c/Counter_Strike_2_Logo.png
MIX_EMBED_THUMB_URL=

# Mix: aviso quando a fila enche (opcional)
MIX_PING_ROLE_ID=
MIX_PING_HERE=

# Tamanho da fila antes do mix (padrão 10). Usa 2 para testar com duas contas.
MIX_QUEUE_MAX=10

# Segundos de espera (em ms) depois de mostrar a fila cheia e antes do aviso / mover voz (padrão 3000).
MIX_QUEUE_FULL_DELAY_MS=3000

# Mix: votação de capitão (quando a fila enche e os times são sorteados)
# Timeout (ms) para encerrar votação; se não votar todo mundo, decide pelo mais votado (empate = sorteio).

# Mix: veto BO3 — timeout (ms) por escolha; se estourar, escolhe aleatório do pool restante.

# Mix: pool de mapas para veto BO3 (se vazio, usa pool padrão do código)
# Formato: separado por vírgulas. Evita espaços.
# Ex.: Mirage,Inferno,Nuke,Anubis,Ancient,Dust 2,Train

# Delay (ms) para apagar as mensagens temporárias do mix após o veto terminar (0 = não apagar).
# Apaga: "fila cheia", "times sorteados", as 2 votações, "capitães definidos", veto, finalização e mensagem da voz.
# NÃO apaga o painel da fila (/mix panel).
MIX_CLEANUP_DELAY_MS=30000

# Mix: lobby de voz (opcional). Se definires, só dá para entrar na fila estando neste canal de voz; ao mover, só move quem ainda está no lobby.
MIX_VOICE_LOBBY_ID=

# Mix: mover para voz ao encher (metade no Time A, metade no Time B)
# IDs dos canais de VOZ (clique direito no canal → Copiar ID). Ambos obrigatórios para mover.
# No Developer Portal → Bot → ativar intent "SERVER MEMBERS INTENT" não é a de voz; para voz usa "GUILD VOICE STATES" (Privileged).
# Permissões do bot no servidor: Ligar, Ver canais, Mover membros, nos dois canais.
MIX_VOICE_TEAM_A_ID=
MIX_VOICE_TEAM_B_ID=
# shuffle (padrão) | order — order = primeira metade da fila = A, segunda = B
MIX_SPLIT_MODE=shuffle
